
<!-- NOTIFICATION BELL -->
<div class="notif-wrapper" style="position:relative;">
    <button class="notif-btn" id="notif-toggle" onclick="toggleNotif()" title="Notifications">
        <i class="fas fa-bell"></i>
        <span class="notif-dot" id="notif-dot" style="display:none;"></span>
        <span class="notif-count" id="notif-count" style="display:none;
              position:absolute;top:-6px;right:-8px;background:#dc3545;color:white;
              border-radius:50%;width:18px;height:18px;font-size:10px;font-weight:700;
              display:none;align-items:center;justify-content:center;"></span>
    </button>

    <!-- DROPDOWN -->
    <div id="notif-dropdown" style="display:none;position:absolute;right:0;top:42px;
         width:340px;max-height:420px;overflow-y:auto;background:white;
         border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.18);
         z-index:9999;border:1px solid #e9ecef;">

        <!-- Header -->
        <div style="padding:14px 16px;border-bottom:1px solid #e9ecef;
                    display:flex;justify-content:space-between;align-items:center;">
            <span style="font-weight:700;font-size:14px;color:#1a1a2e;">Notifications</span>
            <span id="notif-badge" style="background:#e6f4ea;color:#28a745;
                  border-radius:20px;padding:2px 10px;font-size:11px;font-weight:700;">
                0 new
            </span>
        </div>

        <!-- Items -->
        <div id="notif-items" style="padding:8px 0;">
            <div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">
                <i class="fas fa-bell-slash" style="font-size:24px;display:block;margin-bottom:8px;"></i>
                Loading...
            </div>
        </div>
    </div>
</div>

<style>
    .notif-item {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 10px 16px; cursor: pointer; transition: background 0.15s;
        border-bottom: 1px solid #f5f5f5;
    }
    .notif-item:hover { background: #f8f9fa; }
    .notif-item:last-child { border-bottom: none; }
    .notif-icon-wrap {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; flex-shrink: 0;
    }
    .notif-icon-wrap.green  { background: #e6f4ea; color: #28a745; }
    .notif-icon-wrap.red    { background: #ffebee; color: #dc3545; }
    .notif-icon-wrap.blue   { background: #e8f0fe; color: #1a73e8; }
    .notif-icon-wrap.orange { background: #fef3e2; color: #e37400; }
    .notif-title { font-size: 13px; font-weight: 600; color: #1a1a2e; line-height: 1.3; }
    .notif-time  { font-size: 11px; color: #aaa; margin-top: 2px; }

    /* Mobile responsive */
    @@media (max-width: 576px) {
        #notif-dropdown {
            width: calc(100vw - 24px) !important;
            right: -60px !important;
        }
    }
</style>

<script>
    let notifOpen = false;

    function toggleNotif() {
        const dd = document.getElementById('notif-dropdown');
        notifOpen = !notifOpen;
        dd.style.display = notifOpen ? 'block' : 'none';
        if (notifOpen) loadNotifications();
    }

    // Close on outside click
    document.addEventListener('click', function(e) {
        const wrapper = document.querySelector('.notif-wrapper');
        if (wrapper && !wrapper.contains(e.target)) {
            document.getElementById('notif-dropdown').style.display = 'none';
            notifOpen = false;
        }
    });

    async function loadNotifications() {
        const container = document.getElementById('notif-items');
        try {
            const res  = await fetch('/api/notification/list');
            const data = await res.json();

            // Update count badge
            const countEl = document.getElementById('notif-count');
            const dotEl   = document.getElementById('notif-dot');
            const badgeEl = document.getElementById('notif-badge');

            if (data.count > 0) {
                countEl.textContent = data.count > 9 ? '9+' : data.count;
                countEl.style.display = 'flex';
                dotEl.style.display   = 'block';
                badgeEl.textContent   = `${data.count} new`;
            } else {
                countEl.style.display = 'none';
                dotEl.style.display   = 'none';
                badgeEl.textContent   = '0 new';
            }

            if (!data.items || data.items.length === 0) {
                container.innerHTML = `
                    <div style="padding:32px;text-align:center;color:#aaa;font-size:13px;">
                        <i class="fas fa-bell-slash" style="font-size:24px;display:block;margin-bottom:8px;"></i>
                        No notifications yet
                    </div>`;
                return;
            }

            container.innerHTML = data.items.map(n => {
                let colorClass = 'blue';
                if (n.type === 'Approved' || n.type === 'Cleared') colorClass = 'green';
                else if (n.type === 'Declined')  colorClass = 'red';
                else if (n.type === 'Urgent')    colorClass = 'red';
                else if (n.type === 'Pending')   colorClass = 'orange';
                else if (n.type === 'Event')     colorClass = 'blue';

                return `
                    <div class="notif-item">
                        <div class="notif-icon-wrap ${colorClass}">
                            <i class="fas ${n.icon}"></i>
                        </div>
                        <div>
                            <div class="notif-title">${n.title}</div>
                            <div class="notif-time">${n.time}</div>
                        </div>
                    </div>`;
            }).join('');

        } catch (err) {
            container.innerHTML = `
                <div style="padding:24px;text-align:center;color:#aaa;font-size:13px;">
                    Could not load notifications
                </div>`;
        }
    }

    // Auto-load on page load to show count
    loadNotifications();
</script>