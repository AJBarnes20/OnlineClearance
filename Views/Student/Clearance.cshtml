@model IEnumerable<OnlineClearanceSystem.Models.StudentClearanceItem>
@{
    ViewData["Title"]      = "Clearance";
    ViewData["ActivePage"] = "Clearance";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";

    bool hasSubjects = Model != null && Model.Any();
    bool hasConfirmed = TempData["ConfirmedSubjects"] != null
                        || ViewData["HasConfirmed"] is true;
}

<div class="welcome-card mb-4">
    <div>
        <h4>Welcome,</h4>
        <h2>@(ViewData["UserName"] ?? "Student")!</h2>
    </div>
    <div class="period-box">
        <div class="period-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
            <div class="period-label">Active Academic Period</div>
            <div class="period-value">A.Y. 2025-2026, 2nd Semester</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<div class="page-card">
    <div class="page-card-hd dark">
        <i class="fas fa-clipboard-list me-2"></i>SUBJECT ENROLLED
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>CODE</th>
                    <th>SUBJECT</th>
                    <th>DESCRIPTION</th>
                    <th>INSTRUCTOR</th>
                    <th>STATUS</th>
                </tr>
            </thead>
            <tbody>
                @if (hasSubjects)
                {
                    @foreach (var item in Model!)
                    {
                        <tr>
                            <td><span class="code-badge">@item.MisCode</span></td>
                            <td style="font-weight:600;">@item.SubjectCode</td>
                            <td>@item.Description</td>
                            <td>@item.InstructorName</td>
                            <td>
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Pending")
                                {
                                    <span class="status-pending">Pending</span>
                                }
                                else
                                {
                                    <button class="btn-request" onclick="requestSignature(this)">
                                        <i class="fas fa-paper-plane me-1"></i>Request
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <!-- EMPTY STATE -->
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon">
                                    <i class="fas fa-clipboard-list"></i>
                                </div>
                                <div class="empty-title">No subjects enrolled yet</div>
                                <div class="empty-desc">
                                    You haven't confirmed your subjects yet.<br/>
                                    Go to <strong>Subjects Offered</strong> to select
                                    and confirm your enrolled subjects first.
                                </div>
                                <a href="/Student/SubjectsOffered" class="btn-green"
                                   style="display:inline-flex;align-items:center;
                                          gap:8px;padding:10px 28px;
                                          text-decoration:none;margin-top:4px;">
                                    <i class="fas fa-book-open"></i>
                                    Go to Subjects Offered
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
<style>
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 52px 24px;
        text-align: center;
        gap: 12px;
    }
    .empty-icon {
        width: 72px; height: 72px;
        border-radius: 50%;
        background: #f0fdf4;
        border: 2px solid #bbf7d0;
        display: flex; align-items: center; justify-content: center;
        font-size: 28px; color: #16a34a;
        margin-bottom: 4px;
    }
    .empty-title {
        font-size: 16px; font-weight: 700;
        color: #1a1a2e;
    }
    .empty-desc {
        font-size: 13px; color: #888;
        line-height: 1.7; max-width: 340px;
    }
</style>
}

@section Scripts {
<script>
function requestSignature(btn) {
    btn.parentElement.innerHTML = '<span class="status-pending">Pending</span>';
}
</script>
}