@model OnlineClearanceSystem.Models.SubjectOfferedViewModel
@{
    ViewData["Title"]      = "Subjects Offered";
    ViewData["ActivePage"] = "SubjectsOffered";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";

    bool hasSubjects = Model?.AvailableSubjects != null
                       && Model.AvailableSubjects.Any();
}

@if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- STEP 1: SELECT -->
<div id="step-select">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold mb-0" style="color:#1a1a2e;">Subjects Offered</h5>
        <span class="semester-badge">
            <i class="fas fa-calendar-alt me-2"></i>
            @(Model?.ActivePeriod ?? "A.Y. 2025-2026, 2nd Semester")
        </span>
    </div>

    <div class="page-card">
        <div class="page-card-hd dark">
            <i class="fas fa-book-open me-2"></i>Available Subjects — Select yours
        </div>

        @if (hasSubjects)
        {
            <!-- SEARCH BAR -->
            <div style="padding:12px 16px;border-bottom:1px solid var(--border);
                        display:flex;align-items:center;gap:10px;">
                <div style="position:relative;flex:1;max-width:380px;">
                    <i class="fas fa-search"
                       style="position:absolute;left:12px;top:50%;
                              transform:translateY(-50%);color:#aaa;font-size:13px;"></i>
                    <input type="text" id="subject-search"
                           placeholder="Search by code, subject, description or instructor..."
                           oninput="filterSubjects(this.value)"
                           style="width:100%;padding:8px 12px 8px 34px;
                                  border:1px solid #dee2e6;border-radius:8px;
                                  font-size:13px;font-family:inherit;outline:none;" />
                </div>
                <span id="search-count"
                      style="font-size:12px;color:#888;white-space:nowrap;"></span>
            </div>

            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:40px;"></th>
                            <th>CODE</th>
                            <th>SUBJECT</th>
                            <th>DESCRIPTION</th>
                            <th>INSTRUCTOR</th>
                        </tr>
                    </thead>
                    <tbody id="subject-tbody">
                        @foreach (var s in Model!.AvailableSubjects)
                        {
                            <tr class="subject-row"
                                data-code="@s.MisCode.ToLower()"
                                data-subj="@s.SubjectCode.ToLower()"
                                data-desc="@s.Description.ToLower()"
                                data-inst="@s.InstructorName.ToLower()"
                                data-raw-code="@s.MisCode"
                                data-raw-subj="@s.SubjectCode"
                                data-raw-desc="@s.Description"
                                data-raw-inst="@s.InstructorName">
                                <td>
                                    <input type="checkbox"
                                           class="subject-check"
                                           value="@s.Id" />
                                </td>
                                <td><span class="code-badge">@s.MisCode</span></td>
                                <td style="font-weight:600;">@s.SubjectCode</td>
                                <td>@s.Description</td>
                                <td>@s.InstructorName</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div id="no-results"
                     style="display:none;padding:24px;text-align:center;
                            color:#888;font-size:13px;">
                    <i class="fas fa-search me-2"></i>No subjects found.
                </div>
            </div>

            <div style="padding:16px 20px;border-top:1px solid var(--border);
                        text-align:right;">
                <button class="btn-green" onclick="showConfirmStep()">
                    <i class="fas fa-arrow-right me-2"></i>Proceed to Confirm
                </button>
            </div>
        }
        else
        {
            <!-- EMPTY STATE — no subjects in DB yet -->
            <div style="padding:52px 24px;text-align:center;">
                <div style="width:72px;height:72px;border-radius:50%;
                            background:#f0fdf4;border:2px solid #bbf7d0;
                            display:flex;align-items:center;justify-content:center;
                            font-size:28px;color:#16a34a;margin:0 auto 16px;">
                    <i class="fas fa-book-open"></i>
                </div>
                <div style="font-size:16px;font-weight:700;color:#1a1a2e;
                            margin-bottom:8px;">
                    No subjects available yet
                </div>
                <div style="font-size:13px;color:#888;line-height:1.7;
                            max-width:340px;margin:0 auto;">
                    The Admin has not added any subject offerings for the
                    current semester yet. Please check back later.
                </div>
            </div>
        }
    </div>
</div>

<!-- STEP 2: CONFIRM -->
<div id="step-confirm" style="display:none;">
    <div class="page-card">
        <div style="padding:18px 20px;text-align:center;font-size:14px;
                    font-weight:500;color:#333;border-bottom:1px solid var(--border);">
            <i class="fas fa-question-circle me-2" style="color:#1a4731;"></i>
            Are you sure these are all the subjects you're enrolled in this semester?
        </div>
        <div class="page-card-hd" style="font-size:14px;">Selected Subjects</div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>CODE</th>
                        <th>SUBJECT</th>
                        <th>DESCRIPTION</th>
                        <th>INSTRUCTOR</th>
                        <th>ACTION</th>
                    </tr>
                </thead>
                <tbody id="confirm-body"></tbody>
            </table>
        </div>
        <div style="padding:16px 20px;background:#f8f9fa;
                    display:flex;gap:12px;justify-content:space-between;">
            <button class="btn-dark" onclick="backToSelect()">
                <i class="fas fa-arrow-left me-2"></i>BACK
            </button>
            <form asp-action="ConfirmSubjects" asp-controller="Student" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="selectedSubjects" id="selected-hidden" />
                <button type="submit" class="btn-green" onclick="prepareSubmit()">
                    YES &nbsp;→
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Build subject data map from DB rows for use in confirm step
    const subjectData = {
        @if (Model?.AvailableSubjects != null)
        {
            @foreach (var s in Model.AvailableSubjects)
            {
                @($"'{s.Id}': {{ subj: '{s.SubjectCode.Replace("'", "\\'")}', desc: '{s.Description.Replace("'", "\\'")}', inst: '{s.InstructorName.Replace("'", "\\'")}', code: '{s.MisCode.Replace("'", "\\'")}' }},")
            }
        }
    };

    function filterSubjects(query) {
        const q = query.toLowerCase().trim();
        let count = 0;
        document.querySelectorAll('.subject-row').forEach(row => {
            const match = !q
                || row.dataset.code.includes(q)
                || row.dataset.subj.includes(q)
                || row.dataset.desc.includes(q)
                || row.dataset.inst.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) count++;
        });
        document.getElementById('search-count').textContent =
            q ? `${count} result${count !== 1 ? 's' : ''} found` : '';
        document.getElementById('no-results').style.display =
            count === 0 ? 'block' : 'none';
    }

    function showConfirmStep() {
        const selected = [...document.querySelectorAll('.subject-check:checked')]
                            .map(c => c.value);
        if (!selected.length) {
            alert('Please select at least one subject.');
            return;
        }

        const tbody = document.getElementById('confirm-body');
        tbody.innerHTML = '';

        selected.forEach(id => {
            const d = subjectData[id] || {
                code: id, subj: id, desc: '—', inst: '—'
            };
            tbody.innerHTML += `
                <tr id="row-${id}">
                    <td><span class="code-badge">${d.code}</span></td>
                    <td style="font-weight:600;">${d.subj}</td>
                    <td>${d.desc}</td>
                    <td>${d.inst}</td>
                    <td>
                        <button type="button"
                                onclick="removeRow('${id}')"
                                style="background:none;border:none;cursor:pointer;
                                       color:#dc3545;font-size:18px;">
                            <i class="fas fa-times-circle"></i>
                        </button>
                    </td>
                </tr>`;
        });

        document.getElementById('step-select').style.display = 'none';
        document.getElementById('step-confirm').style.display = 'block';
    }

    function removeRow(id) {
        document.getElementById('row-' + id)?.remove();
        const cb = document.querySelector(`.subject-check[value="${id}"]`);
        if (cb) cb.checked = false;

        // If no rows left, go back to select
        if (document.querySelectorAll('#confirm-body tr').length === 0) {
            backToSelect();
        }
    }

    function backToSelect() {
        document.getElementById('step-select').style.display = 'block';
        document.getElementById('step-confirm').style.display = 'none';
        document.getElementById('subject-search').value = '';
        filterSubjects('');
    }

    function prepareSubmit() {
        const codes = [...document.querySelectorAll('#confirm-body tr')]
                        .map(r => r.id.replace('row-', ''));
        document.getElementById('selected-hidden').value = codes.join(',');
    }
</script>
}