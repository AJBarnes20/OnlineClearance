@model IEnumerable<OnlineClearanceSystem.Models.OrganizationSignatory>
@{
    ViewData["Title"]      = "Organization";
    ViewData["ActivePage"] = "Organization";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="welcome-card mb-4">
    <div>
        <h4>Welcome,</h4>
        <h2>@(ViewData["UserName"] ?? "Student")!</h2>
    </div>
    <div class="period-box">
        <div class="period-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
            <div class="period-label">Active Academic Period</div>
            <div class="period-value">A.Y. 2025-2026, 2nd Semester</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<div class="page-card">
    <div class="page-card-hd dark">
        <i class="fas fa-sitemap me-2"></i>Organization
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:60px;">#</th>
                    <th>ORGANIZATION ROLE</th>
                    <th>PERSON ASSIGNED</th>
                    <th>STATUS</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="code-badge">@i</span></td>
                            <td>@item.OrgRole</td>
                            <td style="font-weight:600;">@item.PersonName</td>
                            <td>
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Pending")
                                {
                                    <span class="status-pending">Pending</span>
                                }
                                else
                                {
                                    <button class="btn-request" onclick="requestSignature(this)">
                                        <i class="fas fa-paper-plane me-1"></i>Request
                                    </button>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">
                            <div style="display:flex;flex-direction:column;align-items:center;
                                        justify-content:center;padding:52px 24px;text-align:center;gap:12px;">
                                <div style="width:72px;height:72px;border-radius:50%;
                                            background:#f0fdf4;border:2px solid #bbf7d0;
                                            display:flex;align-items:center;justify-content:center;
                                            font-size:28px;color:#16a34a;">
                                    <i class="fas fa-sitemap"></i>
                                </div>
                                <div style="font-size:16px;font-weight:700;color:#1a1a2e;">
                                    No organization signatories yet
                                </div>
                                <div style="font-size:13px;color:#888;line-height:1.7;max-width:340px;">
                                    The Admin has not set up organization signatories
                                    for your curriculum yet. Please check back later.
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function requestSignature(btn) {
    btn.parentElement.innerHTML = '<span class="status-pending">Pending</span>';
}
</script>
}