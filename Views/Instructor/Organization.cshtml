@model IEnumerable<OnlineClearanceSystem.Models.OrganizationRequest>
@{
    ViewData["Title"]      = "Organization";
    ViewData["ActivePage"] = "Organization";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">Organization</h5>
</div>

<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-sitemap me-2"></i>Organization Requests</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:80px;text-align:center;">NO.</th>
                    <th>POSITION</th><th>REQUESTED</th>
                    <th style="text-align:center;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align:center;"><span class="code-badge">@i.ToString("D2")</span></td>
                            <td style="font-weight:600;">@item.Position</td>
                            <td>
                                <div style="font-weight:600;font-size:13px;">@item.StudentName</div>
                                <div style="font-size:11px;color:#888;">@item.Course</div>
                            </td>
                            <td style="text-align:center;">
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Declined")
                                {
                                    <span class="status-declined">Declined</span>
                                }
                                else
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <form asp-action="ApproveOrg" asp-controller="Instructor" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-approve"><i class="fas fa-check me-1"></i>Cleared</button>
                                        </form>
                                        <form asp-action="DeclineOrg" asp-controller="Instructor" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-decline"><i class="fas fa-times me-1"></i>Declined</button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr><td colspan="4" style="padding:40px;text-align:center;color:#888;">
                        <i class="fas fa-sitemap" style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                        No organization requests yet.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>