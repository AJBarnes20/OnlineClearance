@model IEnumerable<OnlineClearanceSystem.Models.UserManagementItem>
@{
    ViewData["Title"] = "User Management";
    ViewData["ActivePage"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h5 class="fw-bold mb-3" style="color:#1a1a2e;">User Management</h5>

<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-users-cog me-2"></i>All Users</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th><th>USERNAME</th><th>FULL NAME</th>
                    <th>ID NUMBER</th><th>ROLE</th><th>STATUS</th>
                    <th>REGISTERED</th><th style="text-align:center;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Id</td>
                            <td style="font-weight:600;">@u.Username</td>
                            <td>@u.FullName</td>
                            <td><span class="code-badge">@u.IdNumber</span></td>
                            <td>
                                @if (u.Role == "Admin") { <span style="color:var(--green);font-weight:700;">@u.Role</span> }
                                else if (u.Role == "Instructor") { <span style="color:#1a73e8;font-weight:700;">@u.Role</span> }
                                else if (u.Role == "Student") { <span style="color:#0d9488;font-weight:700;">@u.Role</span> }
                                else { <span style="color:#e37400;font-weight:700;">@u.Role</span> }
                            </td>
                            <td>
                                @if (u.IsActive) { <span class="status-approved">Active</span> }
                                else { <span class="status-pending">Inactive</span> }
                            </td>
                            <td style="font-size:12px;color:#888;">@u.CreatedAt</td>
                            <td style="text-align:center;">
                                @if (!u.IsActive || u.Role == "Pending")
                                {
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <form asp-action="ActivateUser" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id"/>
                                            <select name="role" style="padding:4px 8px;border-radius:4px;border:1px solid #dee2e6;font-size:11px;">
                                                <option value="Student">Student</option>
                                                <option value="Instructor">Instructor</option>
                                                <option value="Admin">Admin</option>
                                            </select>
                                            <button type="submit" class="btn-sm-green"><i class="fas fa-check me-1"></i>Activate</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex gap-1 justify-content-center">
                                        <form asp-action="DeactivateUser" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id"/>
                                            <button type="submit" class="btn-sm-gray"><i class="fas fa-ban me-1"></i>Deactivate</button>
                                        </form>
                                        <form asp-action="DeleteUser" method="post" style="display:inline;"
                                              onsubmit="return confirm('Are you sure you want to delete this user?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id"/>
                                            <button type="submit" class="btn-sm-red"><i class="fas fa-trash me-1"></i>Delete</button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" style="padding:40px;text-align:center;color:#888;">
                        <i class="fas fa-users" style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                        No users found.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>