@model IEnumerable<Dictionary<string, string>>
@{
    ViewData["Title"] = "Clearance Overview";
    ViewData["ActivePage"] = "ClearanceOverview";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h5 class="fw-bold mb-3" style="color:#1a1a2e;">Clearance Overview</h5>

<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-clipboard-list me-2"></i>Student Clearance Summary</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>STUDENT</th><th>STUDENT ID</th>
                    <th style="text-align:center;">TOTAL</th>
                    <th style="text-align:center;">CLEARED</th>
                    <th style="text-align:center;">PENDING</th>
                    <th style="text-align:center;">PROGRESS</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var row in Model)
                    {
                        var total   = int.Parse(row["total"]);
                        var cleared = int.Parse(row["cleared"]);
                        var pct     = total > 0 ? (int)(cleared * 100.0 / total) : 0;

                        <tr>
                            <td style="font-weight:600;">@row["student"]</td>
                            <td><span class="code-badge">@row["id"]</span></td>
                            <td style="text-align:center;font-weight:700;">@total</td>
                            <td style="text-align:center;"><span class="status-approved">@cleared</span></td>
                            <td style="text-align:center;"><span class="status-pending">@row["pending"]</span></td>
                            <td style="text-align:center;">
                                <div style="background:#e9ecef;border-radius:20px;height:8px;width:100px;display:inline-block;overflow:hidden;">
                                    <div style="background:@(pct==100?"#28a745":"#e37400");height:100%;width:@(pct)%;border-radius:20px;"></div>
                                </div>
                                <span style="font-size:11px;font-weight:700;color:#555;margin-left:6px;">@pct%</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" style="padding:40px;text-align:center;color:#888;">
                        <i class="fas fa-clipboard-list" style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                        No clearance data yet.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>