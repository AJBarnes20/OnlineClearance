@{
    ViewData["Title"]      = "Student";
    ViewData["ActivePage"] = "Student";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string view = ViewData["SubView"]?.ToString() ?? "all";
}

<div class="page-title">Students</div>

@if (view == "all" || view == "cleared" || view == "incomplete")
{
    <div class="row g-3 mb-4">
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;">
                <div style="font-size:12px;color:var(--muted);font-weight:600;">Total Students</div>
                <div class="stat-num" id="stat-total">0</div>
                <div style="font-size:11px;color:var(--muted);">All year levels</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;border-top:3px solid var(--green);">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--green);font-weight:700;"><i class="fas fa-check-circle"></i> Cleared</div>
                <div class="stat-num" id="stat-cleared">0</div>
                <div style="font-size:11px;color:var(--muted);" id="stat-cleared-sub">No records yet</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;border-top:3px solid var(--red);">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#fc8181;font-weight:700;"><i class="fas fa-clock"></i> Pending</div>
                <div class="stat-num" id="stat-pending">0</div>
                <div style="font-size:11px;color:var(--muted);" id="stat-pending-sub">No records yet</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card"
                 style="flex-direction:column;align-items:center;gap:6px;background:rgba(66,153,225,0.12);border-color:rgba(66,153,225,0.3);cursor:pointer;"
                 onclick="showAssign()">
                <div class="stat-icon-wrap si-blue" style="width:44px;height:44px;"><i class="fas fa-user-plus"></i></div>
                <div style="font-size:12px;font-weight:700;color:#63b3ed;text-align:center;">Assign Signatories</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a href="/Admin/Student"           class="ann-filter-btn @(view=="all"?"active":"")">All Students</a>
        <a href="/Admin/StudentCleared"    class="ann-filter-btn" style="@(view=="cleared"   ?"background:var(--green);color:white;border-color:var(--green);":"")">Cleared</a>
        <a href="/Admin/StudentIncomplete" class="ann-filter-btn" style="@(view=="incomplete"?"background:var(--red);color:white;border-color:var(--red);":"")">Pending</a>
    </div>

    <div class="panel">
        <div class="panel-hd">
            <span class="panel-hd-title">
                @if (view == "cleared")        { <text>Cleared Student Clearance</text> }
                else if (view == "incomplete") { <text>Pending Student Clearance</text> }
                else                           { <text>All Student list accounts</text> }
            </span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search Student, Id, Course..." oninput="filterTable(this,'stu-table')" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="stu-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Student ID</th>
                        @if (view == "all") { <th>Course</th><th>Year / Section</th> }
                        <th>Clearance Status</th>
                    </tr>
                </thead>
                <tbody id="stu-tbody"></tbody>
            </table>
        </div>

        <div id="stu-empty" style="display:none;padding:56px 24px;text-align:center;">
            <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Students Registered Yet</div>
            <div style="font-size:13px;color:var(--muted);max-width:420px;margin:0 auto;line-height:1.6;">
                Student accounts will appear here once they complete their registration.
            </div>
        </div>
    </div>
}

@if (view == "assign")
{
    <div class="panel mb-4">
        <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;color:white;display:flex;align-items:center;justify-content:space-between;">
            <span><i class="fas fa-user-plus me-2"></i>Assign Student Organization Signatories</span>
            <a href="/Admin/Student"
               style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;text-decoration:none;">
                <i class="fas fa-times me-1"></i>Close
            </a>
        </div>
        <div style="padding:20px;">
            <div style="background:rgba(66,153,225,0.08);border:1px solid rgba(66,153,225,0.25);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:12px;color:var(--muted);display:flex;align-items:flex-start;gap:10px;">
                <i class="fas fa-info-circle" style="color:#4299e1;margin-top:2px;flex-shrink:0;"></i>
                <span>Only registered students can be assigned as signatories. Search and select a student below, then enter their position.</span>
            </div>
            <div class="row g-3">

                <div class="col-12">
                    <label class="dark-label">Search & Select Student</label>
                    <div class="position-relative">
                        <input class="dark-input" id="input-student-search"
                               placeholder="Type name or student ID..."
                               autocomplete="off"
                               oninput="filterStudentDropdown(this.value)"
                               onfocus="showStudentDropdown()"
                               style="padding-right:36px;" />
                        <i class="fas fa-search" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;"></i>
                    </div>
                    <!-- Dropdown list -->
                    <div id="student-dropdown"
                         style="display:none;position:absolute;z-index:999;background:var(--card);border:1px solid var(--border);border-radius:8px;max-height:220px;overflow-y:auto;width:calc(100% - 48px);box-shadow:0 8px 24px rgba(0,0,0,0.3);margin-top:4px;">
                    </div>
                    <!-- Selected student pill -->
                    <div id="selected-student-pill" style="display:none;margin-top:10px;background:rgba(66,153,225,0.12);border:1px solid rgba(66,153,225,0.3);border-radius:8px;padding:10px 14px;display:none;align-items:center;justify-content:space-between;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div id="pill-avatar" class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;"></div>
                            <div>
                                <div id="pill-name" style="font-size:13px;font-weight:700;color:var(--text);"></div>
                                <div id="pill-meta" style="font-size:11px;color:var(--muted);margin-top:2px;"></div>
                            </div>
                        </div>
                        <button onclick="clearSelectedStudent()"
                                style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:4px 6px;"
                                title="Remove selection">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>

                <div class="col-12">
                    <label class="dark-label">Position</label>
                    <input class="dark-input" id="input-pos" placeholder="e.g. SSG Treasurer" />
                </div>

                <div class="col-12">
                    <button class="btn-blue-sm" onclick="addSignatory()">
                        <i class="fas fa-plus me-2"></i>Add Signatory
                    </button>
                </div>
            </div>
        </div>

        <div style="background:var(--tbl-hd-navy);padding:11px 18px;font-size:13px;font-weight:700;color:white;">
            List of Student Signatories
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Student ID</th>
                        <th>Course / Year / Section</th>
                        <th>Position</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="signatory-tbody"></tbody>
            </table>
            <div id="signatory-empty" style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
                <i class="fas fa-list-ul" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
                No signatories assigned yet.
            </div>
        </div>
    </div>
}


@section Scripts {
<script>
    let allStudents    = [];
    let signatories    = [];
    let courseSections = {};
    let selectedStudent = null;
    const currentView = '@(ViewData["SubView"]?.ToString() ?? "all")';

    async function loadStudents() {
        try {
            const [stuRes, courseRes] = await Promise.all([
                fetch('/api/admin/students'),
                fetch('/api/admin/courses')
            ]);
            allStudents = await stuRes.json();
            const courses = await courseRes.json();
            buildCourseDropdown(courses);
        } catch {
            allStudents = [];
        }
        renderStudentTable();
        updateStudentStats();
    }

    // ── Load saved signatories from DB ───────────────
    async function loadSignatories() {
        try {
            const res   = await fetch('/api/admin/student-signatories');
            const data  = await res.json();
            signatories = data.map(s => {
                const yl  = s.year > 0 ? `${s.year}${['st','nd','rd'][s.year-1]||'th'} Year` : '—';
                const sec = s.section !== '—' ? s.section : '—';
                return {
                    id   : s.id,
                    name : s.name,
                    idNum: s.idNum,
                    sec  : [s.course !== '—' ? s.course : '', yl, sec].filter(x => x && x !== '—').join(' / ') || '—',
                    pos  : s.position
                };
            });
        } catch { signatories = []; }
        renderSignatories();
    }

    function buildCourseDropdown(courses) {
        const sel = document.getElementById('course-select');
        if (!sel) return;
        sel.innerHTML = '<option value="">-- Select Course --</option>';
        courses.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.code;
            opt.textContent = `${c.code} — ${c.name}`;
            sel.appendChild(opt);
            courseSections[c.code] = [...new Set(
                allStudents
                    .filter(s => s.course === c.code)
                    .map(s => `${s.course}-${s.year}${s.section}`)
                    .filter(x => !x.includes('undefined') && !x.includes('—'))
            )];
        });
    }

    function renderStudentTable() {
        const tbody = document.getElementById('stu-tbody');
        const empty = document.getElementById('stu-empty');
        if (!tbody) return;

        let filtered = allStudents;
        if (currentView === 'cleared')    filtered = allStudents.filter(s => s.cs === 'Cleared');
        if (currentView === 'incomplete') filtered = allStudents.filter(s => s.cs !== 'Cleared');

        tbody.innerHTML = '';
        if (filtered.length === 0) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';

        filtered.forEach((s, idx) => {
            const tr  = document.createElement('tr');
            const yl  = s.year > 0 ? `${s.year}${['st','nd','rd'][s.year-1]||'th'} Year` : '—';
            const sec = (s.section && s.section !== '—') ? s.section : '—';
            const csBadge = s.cs === 'Cleared'
                ? `<span style="background:rgba(56,161,105,0.15);color:#68d391;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">Cleared</span>`
                : `<span style="background:rgba(229,62,62,0.15);color:#fc8181;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">Pending</span>`;
            const courseBadge = (s.course && s.course !== '—')
                ? `<span style="background:rgba(66,153,225,0.15);color:#63b3ed;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">${escHtml(s.course)}</span>`
                : `<span style="color:var(--muted);font-size:12px;">Not assigned</span>`;

            tr.innerHTML = `
                <td style="color:var(--muted);">${String(idx+1).padStart(2,'0')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(s.name.charAt(0))}</div>
                        ${escHtml(s.name)}
                    </div>
                </td>
                <td><span class="badge-active" style="font-size:11px;">${escHtml(s.idNum)}</span></td>
                ${currentView === 'all' ? `<td>${courseBadge}</td><td style="color:var(--muted);font-size:13px;">${yl} / ${escHtml(sec)}</td>` : ''}
                <td>${csBadge}</td>`;
            tbody.appendChild(tr);
        });
    }

    function updateStudentStats() {
        const total   = allStudents.length;
        const cleared = allStudents.filter(s => s.cs === 'Cleared').length;
        const pending = allStudents.filter(s => s.cs !== 'Cleared').length;

        const elTotal      = document.getElementById('stat-total');
        const elCleared    = document.getElementById('stat-cleared');
        const elPending    = document.getElementById('stat-pending');
        const elClearedSub = document.getElementById('stat-cleared-sub');
        const elPendingSub = document.getElementById('stat-pending-sub');

        if (elTotal)      elTotal.textContent      = total;
        if (elCleared)    elCleared.textContent    = cleared;
        if (elPending)    elPending.textContent    = pending;
        if (elClearedSub) elClearedSub.textContent = cleared > 0 ? `${cleared} student(s)` : 'No records yet';
        if (elPendingSub) elPendingSub.textContent = pending > 0 ? `${pending} student(s)` : 'No records yet';
    }

    // ── Student search dropdown ───────────────────────
    function showStudentDropdown() {
        filterStudentDropdown(document.getElementById('input-student-search')?.value || '');
    }

    function filterStudentDropdown(q) {
        const dd = document.getElementById('student-dropdown');
        if (!dd) return;
        const term = q.toLowerCase().trim();

        const assignedIds = signatories.map(s => s.id);
        const matches = allStudents.filter(s =>
            !assignedIds.includes(s.id) &&
            (s.name.toLowerCase().includes(term) || s.idNum.toLowerCase().includes(term))
        ).slice(0, 8);

        if (matches.length === 0) {
            dd.innerHTML = `<div style="padding:12px 16px;font-size:12px;color:var(--muted);text-align:center;">No students found.</div>`;
        } else {
            dd.innerHTML = matches.map(s => {
                const yl   = s.year > 0 ? `${s.year}${['st','nd','rd'][s.year-1]||'th'} Year` : '';
                const sec  = s.section !== '—' ? s.section : '';
                const meta = [s.course !== '—' ? s.course : '', yl, sec].filter(Boolean).join(' · ') || 'No course assigned';
                return `<div onclick="selectStudent(${s.id})"
                    style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;transition:background 0.15s;"
                    onmouseover="this.style.background='rgba(66,153,225,0.08)'"
                    onmouseout="this.style.background=''">
                    <div class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;">${escHtml(s.name.charAt(0))}</div>
                    <div>
                        <div style="font-size:13px;font-weight:600;color:var(--text);">${escHtml(s.name)}</div>
                        <div style="font-size:11px;color:var(--muted);margin-top:1px;">${escHtml(s.idNum)} &nbsp;·&nbsp; ${escHtml(meta)}</div>
                    </div>
                </div>`;
            }).join('');
        }
        dd.style.display = 'block';
    }

    function selectStudent(id) {
        selectedStudent = allStudents.find(s => s.id === id);
        if (!selectedStudent) return;

        document.getElementById('student-dropdown').style.display = 'none';
        document.getElementById('input-student-search').value = '';

        const yl   = selectedStudent.year > 0 ? `${selectedStudent.year}${['st','nd','rd'][selectedStudent.year-1]||'th'} Year` : '';
        const sec  = selectedStudent.section !== '—' ? selectedStudent.section : '';
        const meta = [selectedStudent.course !== '—' ? selectedStudent.course : '', yl, sec].filter(Boolean).join(' · ') || 'No course assigned';

        document.getElementById('pill-avatar').textContent = selectedStudent.name.charAt(0);
        document.getElementById('pill-name').textContent   = selectedStudent.name;
        document.getElementById('pill-meta').textContent   = `${selectedStudent.idNum}  ·  ${meta}`;

        document.getElementById('selected-student-pill').style.display = 'flex';
    }

    function clearSelectedStudent() {
        selectedStudent = null;
        document.getElementById('selected-student-pill').style.display = 'none';
        document.getElementById('input-student-search').value = '';
        document.getElementById('student-dropdown').style.display = 'none';
    }

    document.addEventListener('click', e => {
        const dd    = document.getElementById('student-dropdown');
        const input = document.getElementById('input-student-search');
        if (dd && input && !dd.contains(e.target) && e.target !== input)
            dd.style.display = 'none';
    });

    // ── Add signatory — now saves to DB ──────────────
    async function addSignatory() {
        if (!selectedStudent) { alert('Please select a student first.'); return; }
        const pos = document.getElementById('input-pos')?.value.trim();
        if (!pos) { alert('Please enter a position.'); return; }

        if (signatories.find(s => s.id === selectedStudent.id)) {
            alert('This student is already in the signatories list.');
            return;
        }

        try {
            const res  = await fetch('/api/admin/student-signatories', {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({ userId: selectedStudent.id, position: pos })
            });
            const data = await res.json();
            if (!data.success) { alert('Error: ' + (data.error ?? 'Unknown error')); return; }

            const yl  = selectedStudent.year > 0 ? `${selectedStudent.year}${['st','nd','rd'][selectedStudent.year-1]||'th'} Year` : '—';
            const sec = selectedStudent.section !== '—' ? selectedStudent.section : '—';

            signatories.push({
                id   : data.id,
                name : selectedStudent.name,
                idNum: selectedStudent.idNum,
                sec  : [selectedStudent.course !== '—' ? selectedStudent.course : '', yl, sec].filter(x => x && x !== '—').join(' / ') || '—',
                pos
            });

            renderSignatories();
            clearSelectedStudent();
            document.getElementById('input-pos').value = '';
        } catch (e) { alert('Error: ' + e.message); }
    }

    // ── Remove signatory — now deletes from DB ────────
    async function removeSignatory(id) {
        if (!confirm('Remove this signatory?')) return;
        try {
            await fetch(`/api/admin/student-signatories/${id}`, { method: 'DELETE' });
            signatories = signatories.filter(s => s.id !== id);
            renderSignatories();
        } catch { }
    }

    function renderSignatories() {
        const tbody = document.getElementById('signatory-tbody');
        const empty = document.getElementById('signatory-empty');
        if (!tbody) return;
        tbody.innerHTML = '';
        if (signatories.length === 0) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';

        signatories.forEach((s, i) => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(s.name.charAt(0))}</div>
                        ${escHtml(s.name)}
                    </div>
                </td>
                <td><span class="badge-active" style="font-size:11px;">${escHtml(s.idNum)}</span></td>
                <td style="color:var(--muted);font-size:13px;">${escHtml(s.sec)}</td>
                <td>${escHtml(s.pos)}</td>
                <td>
                    <button onclick="removeSignatory(${s.id})"
                        style="background:rgba(229,62,62,0.12);border:none;color:#e53e3e;border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">
                        <i class="fas fa-trash-alt me-1"></i>Remove
                    </button>
                </td>`;
            tbody.appendChild(row);
        });
    }

    function filterTable(input, id) {
        const q = input.value.toLowerCase();
        document.querySelectorAll('#'+id+' tbody tr').forEach(r =>
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
        );
    }

    function showAssign() { window.location.href = '/Admin/StudentAssign'; }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Replace the bottom of your script:

async function loadStudents() {
    try {
        const [stuRes, courseRes] = await Promise.all([
            fetch('/api/admin/students'),
            fetch('/api/admin/courses')
        ]);

        const stuData    = await stuRes.json();
        const courseData = await courseRes.json();

        allStudents = Array.isArray(stuData) ? stuData : [];
        buildCourseDropdown(courseData);
    } catch (e) {
        console.error('loadStudents error:', e);
        allStudents = [];
    }
    renderStudentTable();
    updateStudentStats();
}

async function loadSignatories() {
    try {
        const res  = await fetch('/api/admin/student-signatories');
        const data = await res.json();

        signatories = Array.isArray(data) ? data.map(s => {
            const yl  = s.year > 0 ? `${s.year}${['st','nd','rd'][s.year-1]||'th'} Year` : '—';
            const sec = s.section !== '—' ? s.section : '—';
            return {
                id   : s.id,
                name : s.name,
                idNum: s.idNum,
                sec  : [s.course !== '—' ? s.course : '', yl, sec].filter(x => x && x !== '—').join(' / ') || '—',
                pos  : s.position
            };
        }) : [];
    } catch (e) {
        console.error('loadSignatories error:', e);
        signatories = [];
    }
    renderSignatories();
}

// Bottom of script — run independently, never block each other
loadStudents();
loadSignatories();

</script>
}