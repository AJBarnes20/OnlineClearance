@model OnlineClearanceSystem.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    ViewData["AdminName"] = Model?.AdminName ?? "Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 style="font-size:22px;font-weight:800;color:#1a1a2e;">
            Welcome back, <span style="color:var(--green);">@(Model?.AdminName ?? "Admin")!</span>
        </h4>
        <p style="font-size:13px;color:#888;margin:0;">System overview and management</p>
    </div>
    <div class="period-box" style="background:white;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <div class="period-icon" style="background:#e6f4ea;">
            <i class="fas fa-calendar-alt" style="color:var(--green);"></i>
        </div>
        <div>
            <div class="period-label" style="color:#888;">Active Academic Period</div>
            <div class="period-value" style="color:var(--green);">@(Model?.ActivePeriod ?? "—")</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-user-graduate"></i></div>
            <div><div class="stat-num">@(Model?.TotalStudents ?? 0)</div><div class="stat-label">Students</div></div></div>
    </div>
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon teal"><i class="fas fa-chalkboard-teacher"></i></div>
            <div><div class="stat-num">@(Model?.TotalInstructors ?? 0)</div><div class="stat-label">Instructors</div></div></div>
    </div>
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon purple"><i class="fas fa-user-tie"></i></div>
            <div><div class="stat-num">@(Model?.TotalStaff ?? 0)</div><div class="stat-label">Admin/Staff</div></div></div>
    </div>
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon orange"><i class="fas fa-user-clock"></i></div>
            <div><div class="stat-num">@(Model?.PendingUsers ?? 0)</div><div class="stat-label">Pending Users</div></div></div>
    </div>
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
            <div><div class="stat-num">@(Model?.TotalCleared ?? 0)</div><div class="stat-label">Cleared</div></div></div>
    </div>
    <div class="col-md-2 col-sm-4">
        <div class="stat-card"><div class="stat-icon red"><i class="fas fa-clock"></i></div>
            <div><div class="stat-num">@(Model?.TotalPending ?? 0)</div><div class="stat-label">Pending Clearance</div></div></div>
    </div>
</div>

<!-- ANNOUNCEMENTS -->
<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-bullhorn me-2"></i>Recent Announcements</div>
    <div style="padding:16px;">
        @if (Model?.Announcements != null && Model.Announcements.Any())
        {
            @foreach (var ann in Model.Announcements)
            {
                <div class="ann-card">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="ann-avatar">SA</div>
                            <div>
                                <div style="font-weight:700;font-size:12px;">System Administrator</div>
                                <div style="font-size:11px;color:#888;">@ann.Date</div>
                            </div>
                        </div>
                        <span class="ann-tag" style="background:#f3f4f6;color:#555;">@ann.Type</span>
                    </div>
                    <div style="font-weight:700;font-size:13px;margin-bottom:4px;">@ann.Title</div>
                    <div style="font-size:12px;color:#555;line-height:1.6;">@ann.Content</div>
                </div>
            }
        }
        else
        {
            <div style="text-align:center;padding:40px;color:#aaa;">
                <i class="fas fa-bullhorn" style="font-size:28px;display:block;margin-bottom:10px;"></i>
                No announcements yet.
            </div>
        }
    </div>
</div>