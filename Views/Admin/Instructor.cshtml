@{
    ViewData["Title"]      = "Instructor";
    ViewData["ActivePage"] = "Instructor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string view = ViewData["SubView"]?.ToString() ?? "all";
}

<div class="page-title">Instructors</div>

@if (view == "all")
{
    <!-- STATS -->
    <div class="row g-3 mb-4">
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;">
                <div style="font-size:12px;color:var(--muted);font-weight:600;">Total Instructors</div>
                <div class="stat-num" id="stat-total">0</div>
                <div style="font-size:11px;color:var(--muted);">All Departments</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;border-top:3px solid #38a169;">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#38a169;font-weight:700;">
                    <i class="fas fa-user-check"></i> Signatories
                </div>
                <div class="stat-num" id="stat-signatories">0</div>
                <div style="font-size:11px;color:var(--muted);" id="stat-sig-sub">No records yet</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="flex-direction:column;align-items:flex-start;gap:4px;border-top:3px solid #4299e1;">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#4299e1;font-weight:700;">
                    <i class="fas fa-id-badge"></i> With Employee ID
                </div>
                <div class="stat-num" id="stat-withid">0</div>
                <div style="font-size:11px;color:var(--muted);">Assigned IDs</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card"
                 style="flex-direction:column;align-items:center;gap:6px;background:rgba(159,122,234,0.12);border-color:rgba(159,122,234,0.3);cursor:pointer;"
                 onclick="window.location.href='/Admin/InstructorAssign'">
                <div class="stat-icon-wrap si-purple" style="width:44px;height:44px;"><i class="fas fa-user-plus"></i></div>
                <div style="font-size:12px;font-weight:700;color:#9f7aea;text-align:center;">Assign Signatories</div>
            </div>
        </div>
    </div>

    <!-- INSTRUCTOR LIST PANEL -->
    <div style="font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;">
        ALL INSTRUCTOR ACCOUNT LIST
    </div>

    <div class="panel" id="instructor-list" style="padding:56px 24px;text-align:center;">
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
            <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Instructors Registered Yet</div>
        <div style="font-size:13px;color:var(--muted);max-width:420px;margin:0 auto;line-height:1.6;">
            Instructor accounts will appear here once they complete their registration.
        </div>
    </div>

    <!-- INSTRUCTOR DETAIL PANEL -->
    <div id="detail-panel" style="display:none;" class="mt-3">
        <div class="panel">
            <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;color:white;
                        display:flex;align-items:center;justify-content:space-between;border-radius:10px 10px 0 0;">
                <span><i class="fas fa-user me-2"></i>Instructor Detail — <span id="det-header-name" style="color:#63b3ed;"></span></span>
                <button onclick="closeDetail()"
                        style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;padding:4px 14px;font-size:12px;cursor:pointer;">
                    <i class="fas fa-times me-1"></i>Close
                </button>
            </div>
            <div style="padding:20px;">
                <div style="background:var(--card);border-radius:12px;border:1px solid var(--border);
                            padding:18px 22px;display:flex;align-items:center;gap:18px;margin-bottom:20px;">
                    <div style="width:58px;height:58px;border-radius:50%;background:rgba(66,153,225,0.15);
                                display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <span id="det-avatar" style="font-size:24px;font-weight:800;color:#4299e1;"></span>
                    </div>
                    <div>
                        <div id="det-name" style="font-size:18px;font-weight:800;color:var(--text);"></div>
                        <div id="det-eid-label" style="font-size:12px;color:var(--muted);margin-top:3px;"></div>
                    </div>
                    <div style="margin-left:auto;">
                        <span style="background:rgba(56,161,105,0.15);color:#38a169;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;">Active</span>
                    </div>
                </div>

                <div id="det-error" style="display:none;background:rgba(229,62,62,0.10);border:1px solid rgba(229,62,62,0.3);
                     border-radius:10px;padding:16px;text-align:center;margin-bottom:16px;">
                    <i class="fas fa-exclamation-triangle" style="color:#fc8181;font-size:20px;margin-bottom:8px;display:block;"></i>
                    <div id="det-error-msg" style="font-size:12px;color:var(--muted);"></div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="panel" style="margin-bottom:0;">
                            <div style="padding:13px 16px;border-bottom:1px solid var(--border);font-size:13px;font-weight:700;color:var(--text);">
                                <i class="fas fa-id-card me-2" style="color:#4299e1;"></i>Profile Information
                            </div>
                            <div style="padding:16px;">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="dark-label">First Name</label>
                                        <input class="dark-input" id="det-first" type="text" readonly />
                                    </div>
                                    <div class="col-12">
                                        <label class="dark-label">Middle Name</label>
                                        <input class="dark-input" id="det-middle" type="text" readonly />
                                    </div>
                                    <div class="col-12">
                                        <label class="dark-label">Last Name</label>
                                        <input class="dark-input" id="det-last" type="text" readonly />
                                    </div>
                                    <div class="col-12">
                                        <label class="dark-label">Employee ID</label>
                                        <input class="dark-input" id="det-eid" type="text" readonly />
                                    </div>
                                    <div class="col-12">
                                        <label class="dark-label">Class Adviser</label>
                                        <input class="dark-input" id="det-section" type="text" readonly />
                                    </div>
                                    <div class="col-12">
                                        <label class="dark-label">Organization Position</label>
                                        <input class="dark-input" id="det-position" type="text" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="panel" style="margin-bottom:0;">
                            <div style="background:var(--tbl-hd-navy);padding:12px 16px;font-size:13px;font-weight:700;color:white;border-radius:10px 10px 0 0;">
                                <i class="fas fa-pen-nib me-2"></i>Verified E-Signature
                            </div>
                            <div style="padding:16px;">
                                <div style="font-size:12px;font-weight:600;color:var(--muted);margin-bottom:10px;">Current E-Signature</div>
                                <div style="background:#111827;border-radius:8px;height:120px;display:flex;align-items:center;
                                            justify-content:center;border:1px solid var(--border);margin-bottom:10px;">
                                    <span style="font-size:28px;color:rgba(255,255,255,0.2);font-style:italic;font-family:serif;">~ signature ~</span>
                                </div>
                                <div style="font-size:11px;color:var(--muted);text-align:right;">Not yet uploaded</div>
                                <div style="margin-top:12px;text-align:center;">
                                    <span style="background:rgba(56,161,105,0.15);color:#38a169;border-radius:8px;
                                                 padding:8px 22px;font-size:13px;font-weight:700;display:inline-block;">
                                        Verified &amp; Active
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (view == "assign")
{
    <div class="panel mb-4">
        <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;color:white;
                    display:flex;align-items:center;justify-content:space-between;border-radius:10px 10px 0 0;">
            <span><i class="fas fa-sitemap me-2"></i>Assign Instructor Organization Signatories</span>
            <a href="/Admin/Instructor"
               style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;
                      padding:4px 12px;font-size:12px;cursor:pointer;text-decoration:none;">
                <i class="fas fa-times me-1"></i>Close
            </a>
        </div>
        <div style="padding:20px;">
            <div style="background:rgba(66,153,225,0.08);border:1px solid rgba(66,153,225,0.25);border-radius:8px;
                        padding:12px 16px;margin-bottom:20px;font-size:12px;color:var(--muted);
                        display:flex;align-items:flex-start;gap:10px;">
                <i class="fas fa-info-circle" style="color:#4299e1;margin-top:2px;flex-shrink:0;"></i>
                <span>Only registered instructors can be assigned as signatories. Search and select an instructor below, then enter their position.</span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-12">
                    <label class="dark-label">Search & Select Instructor</label>
                    <div style="position:relative;">
                        <input class="dark-input" id="input-instructor-search"
                               placeholder="Type name or employee ID..."
                               autocomplete="off"
                               oninput="filterInstructorDropdown(this.value)"
                               onfocus="showInstructorDropdown()"
                               style="padding-right:36px;" />
                        <i class="fas fa-search" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;"></i>
                        <!-- ✅ Dropdown inside relative parent -->
                        <div id="instructor-dropdown"
                             style="display:none;position:absolute;top:100%;left:0;right:0;z-index:9999;
                                    background:var(--card);border:1px solid var(--border);border-radius:8px;
                                    max-height:220px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,0.3);
                                    margin-top:4px;">
                        </div>
                    </div>
                    <!-- Selected pill -->
                    <div id="selected-instructor-pill"
                         style="display:none;margin-top:10px;background:rgba(66,153,225,0.12);
                                border:1px solid rgba(66,153,225,0.3);border-radius:8px;padding:10px 14px;
                                align-items:center;justify-content:space-between;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div id="pill-avatar" class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;"></div>
                            <div>
                                <div id="pill-name" style="font-size:13px;font-weight:700;color:var(--text);"></div>
                                <div id="pill-meta" style="font-size:11px;color:var(--muted);margin-top:2px;"></div>
                            </div>
                        </div>
                        <button onclick="clearSelectedInstructor()"
                                style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:4px 6px;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
                <div class="col-12">
                    <label class="dark-label">Position</label>
                    <input class="dark-input" type="text" id="input-pos" placeholder="e.g. Campus Director, SSG Adviser" />
                </div>
            </div>
            <button class="btn-blue-sm" onclick="addSignatory()">
                <i class="fas fa-plus me-2"></i>Add Signatory
            </button>
        </div>

        <div style="background:var(--tbl-hd-navy);padding:11px 18px;font-size:13px;font-weight:700;color:white;">
            List of Instructor Signatories
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Employee ID</th>
                        <th>Position</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="signatory-tbody"></tbody>
            </table>
            <div id="signatory-empty" style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
                <i class="fas fa-list-ul" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
                No signatories assigned yet. Use the form above to add one.
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    let instructors        = [];
    let signatories        = [];
    let selectedInstructor = null;
    const currentView      = '@(ViewData["SubView"]?.ToString() ?? "all")';

    async function loadInstructors() {
        try {
            const res  = await fetch('/api/admin/instructors');
            const data = await res.json();
            instructors = Array.isArray(data) ? data : [];
        } catch { instructors = []; }
        if (currentView === 'all') { renderInstructors(); updateStats(); }
    }

    async function loadSignatories() {
        try {
            const res  = await fetch('/api/admin/org-signatories');
            const data = await res.json();
            signatories = Array.isArray(data) ? data.map(s => ({
                id:     s.id,
                userId: s.userId,
                name:   s.name,
                eid:    s.eid,
                pos:    s.pos
            })) : [];
        } catch { signatories = []; }
        if (currentView === 'all')    updateStats();
        if (currentView === 'assign') renderSignatories();
    }

    function updateStats() {
        const withId = instructors.filter(i => i.employeeId && i.employeeId !== '—').length;
        document.getElementById('stat-total').textContent       = instructors.length;
        document.getElementById('stat-signatories').textContent = signatories.length;
        document.getElementById('stat-withid').textContent      = withId;
        document.getElementById('stat-sig-sub').textContent     =
            signatories.length > 0 ? `${signatories.length} assigned` : 'No records yet';
    }

    function renderInstructors() {
        const list = document.getElementById('instructor-list');
        if (!list) return;
        if (!instructors.length) {
            list.style.padding = '56px 24px'; list.style.textAlign = 'center';
            list.innerHTML = `
                <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);
                            display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Instructors Registered Yet</div>
                <div style="font-size:13px;color:var(--muted);max-width:420px;margin:0 auto;line-height:1.6;">
                    Instructor accounts will appear here once they complete registration.
                </div>`;
            return;
        }
        list.style.padding = '0'; list.style.textAlign = '';
        list.innerHTML = `
            <div class="panel-hd">
                <span class="panel-hd-title"><i class="fas fa-users me-2"></i>All Instructor Accounts</span>
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input class="search-input" placeholder="Search name, ID..." oninput="filterTable(this,'inst-table')" />
                </div>
            </div>
            <div class="table-responsive">
                <table class="data-table" id="inst-table">
                    <thead>
                        <tr><th>#</th><th>Name</th><th>Employee ID</th><th>Date Joined</th><th>Status</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        ${instructors.map((inst, i) => `
                            <tr>
                                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(inst.name.charAt(0))}</div>
                                        <span style="font-weight:600;">${escHtml(inst.name)}</span>
                                    </div>
                                </td>
                                <td>
                                    ${inst.employeeId && inst.employeeId !== '—'
                                        ? `<span style="background:rgba(66,153,225,0.15);color:#4299e1;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;">${escHtml(inst.employeeId)}</span>`
                                        : `<span style="color:var(--muted);font-size:12px;">Not assigned</span>`}
                                </td>
                                <td style="color:var(--muted);font-size:12px;">${escHtml(inst.joinedDate ?? '—')}</td>
                                <td><span style="background:rgba(56,161,105,0.15);color:#38a169;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">Active</span></td>
                                <td>
                                    <button onclick="viewDetail(${inst.id})"
                                        style="background:#4299e1;color:#fff;border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;">
                                        <i class="fas fa-eye me-1"></i>View
                                    </button>
                                </td>
                            </tr>`).join('')}
                    </tbody>
                </table>
            </div>`;
    }

    async function viewDetail(id) {
        document.getElementById('detail-panel').style.display = 'block';
        document.getElementById('det-error').style.display    = 'none';
        document.getElementById('det-header-name').textContent = 'Loading...';
        document.getElementById('det-name').textContent        = 'Loading...';
        document.getElementById('det-avatar').textContent      = '?';
        document.getElementById('det-eid-label').textContent   = '';
        ['det-first','det-middle','det-last','det-eid','det-section','det-position']
            .forEach(id => document.getElementById(id).value = '');

        setTimeout(() => document.getElementById('detail-panel')
            .scrollIntoView({ behavior:'smooth', block:'start' }), 50);

        try {
            const res  = await fetch(`/api/admin/instructors/${id}`);
            const data = await res.json();
            if (data.error) {
                document.getElementById('det-error').style.display     = 'block';
                document.getElementById('det-error-msg').textContent   = data.error;
                document.getElementById('det-header-name').textContent = 'Error';
                document.getElementById('det-name').textContent        = 'Error';
                return;
            }
            const fullName = [data.firstName, data.middleName, data.lastName]
                .filter(x => x && x !== '—').join(' ');
            document.getElementById('det-header-name').textContent = fullName || '—';
            document.getElementById('det-avatar').textContent      = data.firstName?.charAt(0) ?? '?';
            document.getElementById('det-name').textContent        = fullName || '—';
            document.getElementById('det-eid-label').textContent   = `Employee ID: ${data.employeeId ?? '—'}`;
            document.getElementById('det-first').value             = data.firstName  ?? '—';
            document.getElementById('det-middle').value            = data.middleName ?? '—';
            document.getElementById('det-last').value              = data.lastName   ?? '—';
            document.getElementById('det-eid').value               = data.employeeId ?? '—';
            document.getElementById('det-section').value           = data.section    ?? '—';
            document.getElementById('det-position').value          = data.position   ?? '—';
        } catch (e) {
            document.getElementById('det-error').style.display     = 'block';
            document.getElementById('det-error-msg').textContent   = e.message;
            document.getElementById('det-header-name').textContent = 'Error';
        }
    }

    function closeDetail() { document.getElementById('detail-panel').style.display = 'none'; }

    /* ── Assign page functions ── */
    function showInstructorDropdown() {
        filterInstructorDropdown(document.getElementById('input-instructor-search')?.value || '');
    }

    function filterInstructorDropdown(q) {
        const dd = document.getElementById('instructor-dropdown');
        if (!dd) return;
        const term        = q.toLowerCase().trim();
        const assignedIds = signatories.map(s => s.userId);
        const matches     = instructors.filter(inst =>
            !assignedIds.includes(inst.id) &&
            (term === '' ||
             inst.name.toLowerCase().includes(term) ||
             (inst.employeeId ?? '').toLowerCase().includes(term))
        ).slice(0, 8);

        dd.innerHTML = matches.length === 0
            ? `<div style="padding:12px 16px;font-size:12px;color:var(--muted);text-align:center;">No instructors found.</div>`
            : matches.map(inst => `
                <div onclick="selectInstructor(${inst.id})"
                     style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);
                            display:flex;align-items:center;gap:10px;transition:background 0.15s;"
                     onmouseover="this.style.background='rgba(66,153,225,0.08)'"
                     onmouseout="this.style.background=''">
                    <div class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;">${escHtml(inst.name.charAt(0))}</div>
                    <div>
                        <div style="font-size:13px;font-weight:600;color:var(--text);">${escHtml(inst.name)}</div>
                        <div style="font-size:11px;color:var(--muted);margin-top:1px;">EID: ${escHtml(inst.employeeId ?? '—')}</div>
                    </div>
                </div>`).join('');
        dd.style.display = 'block';
    }

    function selectInstructor(id) {
        selectedInstructor = instructors.find(i => i.id === id);
        if (!selectedInstructor) return;
        document.getElementById('instructor-dropdown').style.display      = 'none';
        document.getElementById('input-instructor-search').value          = '';
        document.getElementById('pill-avatar').textContent                = selectedInstructor.name.charAt(0);
        document.getElementById('pill-name').textContent                  = selectedInstructor.name;
        document.getElementById('pill-meta').textContent                  = `Employee ID: ${selectedInstructor.employeeId ?? '—'}`;
        document.getElementById('selected-instructor-pill').style.display = 'flex';
    }

    function clearSelectedInstructor() {
        selectedInstructor = null;
        document.getElementById('selected-instructor-pill').style.display = 'none';
        document.getElementById('input-instructor-search').value          = '';
        document.getElementById('instructor-dropdown').style.display      = 'none';
    }

    document.addEventListener('click', e => {
        const dd    = document.getElementById('instructor-dropdown');
        const input = document.getElementById('input-instructor-search');
        if (dd && input && !dd.contains(e.target) && e.target !== input)
            dd.style.display = 'none';
    });

    async function addSignatory() {
        if (!selectedInstructor) { alert('Please select an instructor first.'); return; }
        const pos = document.getElementById('input-pos')?.value.trim();
        if (!pos) { alert('Please enter a position.'); return; }
        if (signatories.find(s => s.userId === selectedInstructor.id)) {
            alert('This instructor is already in the signatories list.'); return;
        }
        try {
            const res  = await fetch('/api/admin/org-signatories', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ userId: selectedInstructor.id, eid: selectedInstructor.employeeId, pos })
            });
            const data = await res.json();
            if (data.success) {
                signatories.push({ id: data.id, userId: selectedInstructor.id, name: selectedInstructor.name, eid: selectedInstructor.employeeId, pos });
                renderSignatories();
                clearSelectedInstructor();
                document.getElementById('input-pos').value = '';
            } else { alert('Error: ' + (data.error ?? 'Unknown error')); }
        } catch (e) { alert('Error: ' + e.message); }
    }

    async function removeSignatory(id) {
        if (!confirm('Remove this signatory?')) return;
        try {
            await fetch(`/api/admin/org-signatories/${id}`, { method: 'DELETE' });
            signatories = signatories.filter(s => s.id !== id);
            renderSignatories();
        } catch { }
    }

    function renderSignatories() {
        const tbody = document.getElementById('signatory-tbody');
        const empty = document.getElementById('signatory-empty');
        if (!tbody) return;
        tbody.innerHTML = '';
        if (!signatories.length) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';
        signatories.forEach((s, i) => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(s.name.charAt(0))}</div>
                        <span style="font-weight:600;">${escHtml(s.name)}</span>
                    </div>
                </td>
                <td style="color:var(--muted);">${escHtml(s.eid ?? '—')}</td>
                <td>${escHtml(s.pos)}</td>
                <td>
                    <button onclick="removeSignatory(${s.id})"
                        style="background:rgba(229,62,62,0.12);border:none;color:#e53e3e;
                               border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;font-weight:600;">
                        <i class="fas fa-trash-alt me-1"></i>Remove
                    </button>
                </td>`;
            tbody.appendChild(row);
        });
    }

    function filterTable(input, id) {
        const q = input.value.toLowerCase();
        document.querySelectorAll('#' + id + ' tbody tr').forEach(r =>
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
        );
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadInstructors();
    loadSignatories();
</script>
}