@{
    ViewData["Title"]      = "Instructor";
    ViewData["ActivePage"] = "Instructor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">Instructor</div>

<!-- STATS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-total">0</div>
                <div class="stat-label">Total Instructors</div>
                <div class="stat-sub">All Departments</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-users"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-signatories">0</div>
                <div class="stat-label">Organization Signatories</div>
                <div class="stat-sub">Active Roles</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-user-check"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card"
             id="assign-toggle-card"
             onclick="toggleAssignPanel()"
             style="cursor:pointer;transition:border-color 0.2s,background 0.2s;"
             title="Click to assign organization positions">
            <div>
                <div class="stat-label" style="margin-bottom:8px;">Assign Organization Position</div>
                <div style="font-size:11px;color:var(--muted);" id="assign-toggle-hint">Click to manage</div>
            </div>
            <div class="stat-icon-wrap si-purple"><i class="fas fa-user-plus"></i></div>
        </div>
    </div>
</div>

<!-- INSTRUCTOR LIST -->
<div style="font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;">
    ALL INSTRUCTOR ACCOUNT LIST
</div>

<div class="panel" id="instructor-list" style="padding:56px 24px;text-align:center;">
    <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
        <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
    </div>
    <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Instructors Registered Yet</div>
    <div style="font-size:13px;color:var(--muted);max-width:420px;margin:0 auto;line-height:1.6;">
        Instructor accounts will appear here once they complete their registration.
        As admin, you can assign organization signatory roles using the
        <strong style="color:var(--text);">Assign Organization Position</strong> card above.
    </div>
</div>

<!-- ASSIGN ORG SIGNATORIES SECTION -->
<div class="mt-4 panel" id="assign-panel" style="display:none;">
    <div style="background:var(--tbl-hd-navy);padding:13px 18px;font-size:14px;font-weight:700;color:white;display:flex;align-items:center;justify-content:space-between;">
        <span><i class="fas fa-sitemap me-2"></i>Assign Instructor Organization Signatories</span>
        <button onclick="toggleAssignPanel()"
                style="background:rgba(255,255,255,0.12);border:none;color:white;border-radius:6px;padding:4px 12px;font-size:12px;cursor:pointer;">
            <i class="fas fa-times me-1"></i>Close
        </button>
    </div>

    <div style="padding:20px;">
        <div style="background:rgba(66,153,225,0.08);border:1px solid rgba(66,153,225,0.25);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:12px;color:var(--muted);display:flex;align-items:flex-start;gap:10px;">
            <i class="fas fa-info-circle" style="color:#4299e1;margin-top:2px;flex-shrink:0;"></i>
            <span>Only registered instructors can be assigned as signatories. Search and select an instructor below, then enter their position.</span>
        </div>

        <div class="row g-3 mb-3">

            <!-- Search & Select Instructor -->
            <div class="col-12">
                <label class="dark-label">Search & Select Instructor</label>
                <div class="position-relative">
                    <input class="dark-input" id="input-instructor-search"
                           placeholder="Type name or employee ID..."
                           autocomplete="off"
                           oninput="filterInstructorDropdown(this.value)"
                           onfocus="showInstructorDropdown()"
                           style="padding-right:36px;" />
                    <i class="fas fa-search" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;"></i>
                </div>

                <!-- Dropdown -->
                <div id="instructor-dropdown"
                     style="display:none;position:absolute;z-index:999;background:var(--card);border:1px solid var(--border);border-radius:8px;max-height:220px;overflow-y:auto;width:calc(100% - 48px);box-shadow:0 8px 24px rgba(0,0,0,0.3);margin-top:4px;">
                </div>

                <!-- Selected pill -->
                <div id="selected-instructor-pill"
                     style="display:none;margin-top:10px;background:rgba(66,153,225,0.12);border:1px solid rgba(66,153,225,0.3);border-radius:8px;padding:10px 14px;align-items:center;justify-content:space-between;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div id="pill-avatar" class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;"></div>
                        <div>
                            <div id="pill-name" style="font-size:13px;font-weight:700;color:var(--text);"></div>
                            <div id="pill-meta" style="font-size:11px;color:var(--muted);margin-top:2px;"></div>
                        </div>
                    </div>
                    <button onclick="clearSelectedInstructor()"
                            style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:4px 6px;"
                            title="Remove selection">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <!-- Position -->
            <div class="col-12">
                <label class="dark-label">Position</label>
                <input class="dark-input" type="text" id="input-pos" placeholder="e.g. Campus Director, SSG Adviser" />
            </div>
        </div>

        <button class="btn-blue-sm" onclick="addSignatory()">
            <i class="fas fa-plus me-2"></i>Add Signatory
        </button>
    </div>

    <div style="background:var(--tbl-hd-navy);padding:11px 18px;font-size:13px;font-weight:700;color:white;">
        List of Instructor Signatories
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Employee ID</th>
                    <th>Position</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="signatory-tbody"></tbody>
        </table>
        <div id="signatory-empty" style="padding:36px 24px;text-align:center;color:var(--muted);font-size:13px;">
            <i class="fas fa-list-ul" style="font-size:24px;opacity:0.3;display:block;margin-bottom:10px;"></i>
            No signatories assigned yet. Use the form above to add one.
        </div>
    </div>
</div>

@section Scripts {
<script>
    let instructors      = [];
    let signatories      = [];
    let selectedInstructor = null;
    let assignOpen       = false;

    // ── Load ─────────────────────────────────────────
    async function loadInstructors() {
        try {
            const res  = await fetch('/api/admin/instructors');
            instructors = await res.json();
        } catch { instructors = []; }
        renderInstructors();
    }

    async function loadSignatories() {
        try {
            const res  = await fetch('/api/admin/org-signatories');
            signatories = await res.json();
        } catch { signatories = []; }
        renderSignatories();
        updateStats();
    }

    function updateStats() {
        const elTotal = document.getElementById('stat-total');
        const elSig   = document.getElementById('stat-signatories');
        if (elTotal) elTotal.textContent = instructors.length;
        if (elSig)   elSig.textContent   = signatories.length;
    }

    // ── Render instructor list ────────────────────────
    function renderInstructors() {
    const list = document.getElementById('instructor-list');
    if (!list) return;
    updateStats();

    if (instructors.length === 0) {
        list.style.padding   = '56px 24px';
        list.style.textAlign = 'center';
        list.innerHTML = `
            <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);
                        display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Instructors Registered Yet</div>
            <div style="font-size:13px;color:var(--muted);max-width:420px;margin:0 auto;line-height:1.6;">
                Instructor accounts will appear here once they complete registration.
            </div>`;
        return;
    }

    list.style.padding   = '0';
    list.style.textAlign = '';
    list.innerHTML = `
        <div class="panel-hd">
            <span class="panel-hd-title">All Instructor Accounts</span>
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input class="search-input" placeholder="Search name, username, ID..."
                       oninput="filterTable(this, 'inst-table')" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" id="inst-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Username</th>
                        <th>Employee ID</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    ${instructors.map((inst, i) => `
                        <tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="background:#4299e1;">
                                        ${escHtml(inst.name.charAt(0))}
                                    </div>
                                    ${escHtml(inst.name)}
                                </div>
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(inst.username)}</td>
                            <td>
                                ${inst.employeeId !== '—'
                                    ? `<span class="badge-active" style="font-size:11px;">${escHtml(inst.employeeId)}</span>`
                                    : `<span style="color:var(--muted);font-size:12px;">Not assigned</span>`}
                            </td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(inst.joinedDate)}</td>
                            <td><span class="badge-active">Active</span></td>
                            <td>
                                <a href="/Admin/InstructorDetail?id=${inst.id}"
                                   style="background:#4299e1;color:#fff;border:none;border-radius:6px;
                                          padding:5px 12px;font-size:12px;font-weight:600;
                                          cursor:pointer;text-decoration:none;">
                                    <i class="fas fa-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>`).join('')}
                </tbody>
            </table>
        </div>`;
}

function filterTable(input, id) {
    const q = input.value.toLowerCase();
    document.querySelectorAll('#' + id + ' tbody tr').forEach(r =>
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
    );
}

    // ── Instructor search dropdown ────────────────────
    function showInstructorDropdown() {
        filterInstructorDropdown(document.getElementById('input-instructor-search')?.value || '');
    }

    function filterInstructorDropdown(q) {
        const dd = document.getElementById('instructor-dropdown');
        if (!dd) return;
        const term = q.toLowerCase().trim();

        // exclude already-assigned instructors
        const assignedEids = signatories.map(s => s.eid);
        const matches = instructors.filter(inst =>
            !assignedEids.includes(inst.employeeId) &&
            (inst.name.toLowerCase().includes(term) ||
             inst.employeeId.toLowerCase().includes(term))
        ).slice(0, 8);

        if (matches.length === 0) {
            dd.innerHTML = `<div style="padding:12px 16px;font-size:12px;color:var(--muted);text-align:center;">No instructors found.</div>`;
        } else {
            dd.innerHTML = matches.map(inst => `
                <div onclick="selectInstructor(${inst.id})"
                     style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;transition:background 0.15s;"
                     onmouseover="this.style.background='rgba(66,153,225,0.08)'"
                     onmouseout="this.style.background=''">
                    <div class="user-avatar-sm" style="background:#4299e1;flex-shrink:0;">${escHtml(inst.name.charAt(0))}</div>
                    <div>
                        <div style="font-size:13px;font-weight:600;color:var(--text);">${escHtml(inst.name)}</div>
                        <div style="font-size:11px;color:var(--muted);margin-top:1px;">EID: ${escHtml(inst.employeeId)}</div>
                    </div>
                </div>`).join('');
        }
        dd.style.display = 'block';
    }

    function selectInstructor(id) {
        selectedInstructor = instructors.find(i => i.id === id);
        if (!selectedInstructor) return;

        document.getElementById('instructor-dropdown').style.display = 'none';
        document.getElementById('input-instructor-search').value = '';

        document.getElementById('pill-avatar').textContent = selectedInstructor.name.charAt(0);
        document.getElementById('pill-name').textContent   = selectedInstructor.name;
        document.getElementById('pill-meta').textContent   = `Employee ID: ${selectedInstructor.employeeId}`;

        const pill = document.getElementById('selected-instructor-pill');
        pill.style.display = 'flex';
    }

    function clearSelectedInstructor() {
        selectedInstructor = null;
        document.getElementById('selected-instructor-pill').style.display = 'none';
        document.getElementById('input-instructor-search').value = '';
        document.getElementById('instructor-dropdown').style.display = 'none';
    }

    // close dropdown on outside click
    document.addEventListener('click', e => {
        const dd    = document.getElementById('instructor-dropdown');
        const input = document.getElementById('input-instructor-search');
        if (dd && input && !dd.contains(e.target) && e.target !== input)
            dd.style.display = 'none';
    });

    // ── Add / Remove signatory ────────────────────────
    async function addSignatory() {
        if (!selectedInstructor) { alert('Please select an instructor first.'); return; }
        const pos = document.getElementById('input-pos')?.value.trim();
        if (!pos) { alert('Please enter a position.'); return; }

        if (signatories.find(s => s.eid === selectedInstructor.employeeId)) {
            alert('This instructor is already in the signatories list.');
            return;
        }

        try {
            const res  = await fetch('/api/admin/org-signatories', {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({ eid: selectedInstructor.employeeId, pos })
            });
            const data = await res.json();
            if (data.success) {
                signatories.push({
                    id  : data.id,
                    name: selectedInstructor.name,
                    eid : selectedInstructor.employeeId,
                    pos
                });
                renderSignatories();
                updateStats();
                clearSelectedInstructor();
                document.getElementById('input-pos').value = '';
            } else {
                alert('Error: ' + (data.error ?? 'Unknown error'));
            }
        } catch (e) { alert('Error: ' + e.message); }
    }

    async function removeSignatory(id) {
        if (!confirm('Remove this signatory?')) return;
        try {
            await fetch(`/api/admin/org-signatories/${id}`, { method: 'DELETE' });
            signatories = signatories.filter(s => s.id !== id);
            renderSignatories();
            updateStats();
        } catch { }
    }

    // ── Render signatories table ──────────────────────
    function renderSignatories() {
        const tbody = document.getElementById('signatory-tbody');
        const empty = document.getElementById('signatory-empty');
        if (!tbody) return;
        tbody.innerHTML = '';
        if (signatories.length === 0) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';
        signatories.forEach((s, i) => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(s.name.charAt(0))}</div>
                        ${escHtml(s.name)}
                    </div>
                </td>
                <td style="color:var(--muted);">${escHtml(s.eid)}</td>
                <td>${escHtml(s.pos)}</td>
                <td>
                    <button onclick="removeSignatory(${s.id})"
                        style="background:rgba(229,62,62,0.12);border:none;color:#e53e3e;
                               border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">
                        <i class="fas fa-trash-alt me-1"></i>Remove
                    </button>
                </td>`;
            tbody.appendChild(row);
        });
    }

    // ── Toggle assign panel ───────────────────────────
    function toggleAssignPanel() {
        assignOpen = !assignOpen;
        const panel = document.getElementById('assign-panel');
        const card  = document.getElementById('assign-toggle-card');
        const hint  = document.getElementById('assign-toggle-hint');
        if (assignOpen) {
            panel.style.display    = 'block';
            card.style.borderColor = 'var(--purple, #9f7aea)';
            card.style.background  = 'rgba(159,122,234,0.10)';
            hint.textContent       = 'Click to close';
            setTimeout(() => panel.scrollIntoView({ behavior:'smooth', block:'start' }), 50);
        } else {
            panel.style.display    = 'none';
            card.style.borderColor = '';
            card.style.background  = '';
            hint.textContent       = 'Click to manage';
        }
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadInstructors();
    loadSignatories();
</script>
}