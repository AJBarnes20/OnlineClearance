@{
    ViewData["Title"]      = "Academic Management";
    ViewData["ActivePage"] = "Academic";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title" style="margin-bottom:4px;">Academic Management</div>
        <div style="font-size:13px;color:var(--muted);">Manage Academic Years &amp; Semesters</div>
    </div>
    <button onclick="openModal()"
        style="background:#4299e1;color:#fff;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;">
        <i class="fas fa-plus me-2"></i>Add Academic Year
    </button>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-total">0</div>
                <div class="stat-label">Total Academic Years</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-calendar-alt"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-semesters">0</div>
                <div class="stat-label">Total Semesters</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-layer-group"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-active">0</div>
                <div class="stat-label">Active Period</div>
            </div>
            <div class="stat-icon-wrap si-teal"><i class="fas fa-check-circle"></i></div>
        </div>
    </div>
</div>

<!-- ACADEMIC YEAR TABLE -->
<div class="panel">
    <div class="panel-hd">
        <span class="panel-hd-title" style="color:#4299e1;font-size:15px;">
            <i class="fas fa-calendar-alt me-2"></i>Academic Years &amp; Semesters
        </span>
        <div class="search-wrap">
            <i class="fas fa-search"></i>
            <input type="text" class="search-input" placeholder="Search academic year..."
                oninput="filterTable(this,'academic-table')" />
        </div>
    </div>
    <div class="table-responsive">
        <table class="data-table" id="academic-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Academic Year</th>
                    <th>Semester</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="academic-tbody">
                <!-- Populated from DB / JS -->
            </tbody>
        </table>
    </div>

    <!-- Empty state -->
    <div id="academic-empty" style="padding:56px 24px;text-align:center;">
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
            <i class="fas fa-calendar-alt" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Academic Years Added Yet</div>
        <div style="font-size:13px;color:var(--muted);max-width:380px;margin:0 auto;line-height:1.6;">
            Use the <strong style="color:var(--text);">Add Academic Year</strong> button above to create
            your first academic year and semester. Records will appear here once saved.
        </div>
    </div>
</div>

<!-- ADD / EDIT MODAL -->
<div id="academicModal"
    style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border-radius:14px;padding:30px;width:100%;max-width:460px;border:1px solid var(--border);margin:16px;">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div style="font-size:16px;font-weight:800;color:var(--text);" id="modal-title">
                <i class="fas fa-plus-circle me-2" style="color:#4299e1;"></i>Add Academic Year
            </div>
            <button onclick="closeModal()"
                style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--muted);">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Academic Year</label>
            <input type="text" id="input-ay" placeholder="e.g. 2026-2027"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;" />
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Semester</label>
            <select id="input-sem"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;">
                <option value="1st Semester">1st Semester</option>
                <option value="2nd Semester">2nd Semester</option>
                <option value="Summer">Summer</option>
            </select>
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Start Date</label>
            <input type="date" id="input-start"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;" />
        </div>
        <div class="mb-3">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">End Date</label>
            <input type="date" id="input-end"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;" />
        </div>
        <div class="mb-4">
            <label style="font-size:13px;font-weight:700;color:var(--text);display:block;margin-bottom:5px;">Status</label>
            <select id="input-status"
                style="width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:13px;box-sizing:border-box;">
                <option value="Active">Active</option>
                <option value="Completed">Completed</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button onclick="saveRow()"
                style="flex:1;background:#4299e1;color:#fff;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-save me-1"></i>Save
            </button>
            <button onclick="closeModal()"
                style="flex:1;background:var(--border);color:var(--text);border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">
                Cancel
            </button>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div id="delete-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:400px;margin:16px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(229,62,62,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="fas fa-trash" style="font-size:22px;color:#fc8181;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">Delete Academic Record?</div>
        <div style="font-size:13px;color:var(--muted);margin-bottom:24px;">
            This action cannot be undone. The record will be permanently removed.
        </div>
        <div class="d-flex justify-content-center gap-3">
            <button onclick="closeDeleteModal()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="confirmDelete()"
                style="background:#e53e3e;border:none;color:white;border-radius:8px;padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-trash me-1"></i>Delete
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
let academics     = [];
let editingIndex  = null;
let deletingIndex = null;

async function loadAcademics() {
    try {
        const res = await fetch('/api/admin/academic');
        academics = await res.json();
        renderTable();
    } catch { renderTable(); }
}

async function saveRow() {
    const ay     = document.getElementById('input-ay').value.trim();
    const sem    = document.getElementById('input-sem').value;
    const start  = document.getElementById('input-start').value;
    const end    = document.getElementById('input-end').value;
    const status = document.getElementById('input-status').value;
    if (!ay || !start || !end) { alert('Please fill in all fields.'); return; }

    if (status === 'Active') {
        const existing = academics.findIndex((a, i) => a.status === 'Active' && i !== editingIndex);
        if (existing !== -1) {
            if (!confirm(`"A.Y. ${academics[existing].ay} – ${academics[existing].sem}" is currently Active. Set it to Completed?`)) return;
        }
    }

    try {
        if (editingIndex !== null) {
            const id = academics[editingIndex].id;
            await fetch(`/api/admin/academic/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ay, sem, start, end, status })
            });
        } else {
            await fetch('/api/admin/academic', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ay, sem, start, end, status })
            });
        }
        await loadAcademics();
    } catch { }
    closeModal();
}

async function confirmDelete() {
    const id = academics[deletingIndex].id;
    try {
        await fetch(`/api/admin/academic/${id}`, { method: 'DELETE' });
        await loadAcademics();
    } catch { }
    closeDeleteModal();
}

// Keep all other functions (renderTable, openModal, closeModal, editRow,
// openDeleteModal, closeDeleteModal, filterTable, updateStats, escHtml)
// exactly as they are — only saveRow() and confirmDelete() changed.

loadAcademics();
</script>
}