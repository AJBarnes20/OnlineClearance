@{
    ViewData["Title"]      = "Instructor Detail";
    ViewData["ActivePage"] = "Instructor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">Instructor</div>

<!-- PROFILE HEADER -->
<div style="background:var(--card);border-radius:12px;border:1px solid var(--border);padding:20px 24px;display:flex;align-items:center;gap:20px;margin-bottom:20px;">
    <div style="width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fas fa-user" style="font-size:26px;color:var(--muted);"></i>
    </div>
    <div>
        <div style="font-size:20px;font-weight:800;color:white;">Dr. Glicerio A. Baguia</div>
        <div style="font-size:13px;color:var(--muted);">Instructor ID: 1239477509</div>
    </div>
    <div style="margin-left:auto;"><span class="badge-active">Active</span></div>
</div>

<div class="row g-3">
    <!-- LEFT: Profile Info -->
    <div class="col-md-6">
        <div class="panel">
            <div style="padding:16px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;">Profile Information:</div>
            <div style="padding:18px;">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="dark-label">First Name</label>
                        <input class="dark-input" type="text" value="Glicerio" />
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Middle Initial</label>
                        <input class="dark-input" type="text" value="A" />
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Last Name</label>
                        <input class="dark-input" type="text" value="Baguia" />
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Employee ID</label>
                        <input class="dark-input" type="text" value="7240424" />
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Class Adviser</label>
                        <input class="dark-input" type="text" value="BSIT - 2A" />
                    </div>
                    <div class="col-12">
                        <label class="dark-label">Organization Position</label>
                        <input class="dark-input" type="text" value="Campus Director" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Subject List + E-Signature -->
    <div class="col-md-6">
        <!-- Subject List Button -->
        <a href="/Admin/InstructorSubjects" style="text-decoration:none;">
            <div style="background:#3b82f6;border-radius:10px;padding:14px 20px;display:flex;align-items:center;gap:12px;margin-bottom:14px;cursor:pointer;">
                <i class="fas fa-clipboard-list" style="font-size:18px;color:white;"></i>
                <span style="font-size:15px;font-weight:700;color:white;">Subject List Handled</span>
            </div>
        </a>

        <!-- E-Signature -->
        <div class="panel">
            <div style="background:#1e3a5f;padding:12px 18px;font-size:14px;font-weight:700;color:white;">
                <i class="fas fa-pen-nib me-2"></i>Verified E- Signature
            </div>
            <div style="padding:16px 18px;">
                <div style="font-size:12px;font-weight:600;color:var(--muted);margin-bottom:10px;">Current E-Signature</div>
                <div style="background:#111827;border-radius:8px;height:120px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border);margin-bottom:10px;">
                    <span style="font-size:32px;color:rgba(255,255,255,0.2);font-style:italic;font-family:serif;">~ signature ~</span>
                </div>
                <div style="font-size:11px;color:var(--muted);text-align:right;">Timestamps, 10:53 AM</div>
                <div style="margin-top:12px;text-align:center;">
                    <span style="background:var(--green);color:white;border-radius:8px;padding:8px 24px;font-size:13px;font-weight:700;display:inline-block;">Verified &amp; Active</span>
                </div>
            </div>
        </div>
    </div>
</div>