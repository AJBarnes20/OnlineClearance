@model IEnumerable<OnlineClearanceSystem.Models.AdminSubjectOfferingItem>
@{
    ViewData["Title"] = "Subject Offerings";
    ViewData["ActivePage"] = "SubjectOfferings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h5 class="fw-bold mb-3" style="color:#1a1a2e;">Subject Offerings</h5>

<div class="page-card">
    <div class="page-card-hd dark"><i class="fas fa-book-open me-2"></i>All Subject Offerings</div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>MIS CODE</th><th>SUBJECT</th><th>DESCRIPTION</th>
                    <th>INSTRUCTOR</th><th>PERIOD</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var so in Model)
                    {
                        <tr>
                            <td><span class="code-badge">@so.MisCode</span></td>
                            <td style="font-weight:600;">@so.SubjectCode</td>
                            <td>@so.Description</td>
                            <td>@so.InstructorName</td>
                            <td style="font-size:12px;color:#888;">@so.Period</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="padding:40px;text-align:center;color:#888;">
                        <i class="fas fa-book-open" style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                        No subject offerings yet.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>